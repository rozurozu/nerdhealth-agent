# ============================================================================
# host.env — ホスト固有のパス設定テンプレ。
#
# 使い方:  host.env にコピーして実値に編集する（make init が自動でコピーする）。
#          実体の host.env は git 管理しない（.gitignore 済み）。
#
# ⚠ 秘密(APIキー・トークン)は絶対に書かない。秘密は data/.env が唯一の置き場。
#    ここはホストのパス等だけ。Makefile と scripts/*.sh の両方がこのファイルを読む。
#    形式は KEY=VALUE のみ（= の前後に空白を入れない・クォート不要）。
# ============================================================================

# バックアップの退避先（HDD 推奨）。make backup / 夜間 timer がここに tar を作る。
BACKUP_DIR=/mnt/hdd/nerdhealth-agent/backups

# 退避先が載っているべきマウントポイント。
# これが未マウントなら backup を中止する安全ガード（空マウントポイントへ書く事故を防ぐ）。
# ガード不要（退避先が常設ディスク）なら空にする。
BACKUP_MOUNT=/mnt/hdd

# 保持世代数。新しい順にこの数だけ残し、古いものは自動削除する。
KEEP=30
