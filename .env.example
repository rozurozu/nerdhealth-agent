# ============================================================================
# .env.example — これをコピーして .env を作る（.env は git 管理しない）
#   cp .env.example .env
# ============================================================================

# --- LLM バックエンド（Sakana Fugu / OpenAI 互換） -------------------------
# Hermes の custom provider は OpenAI 互換エンドポイントを OPENAI_API_KEY で認証する。
# ここには Sakana のコンソールで発行した API キーの「値」を入れる。
# （Sakana 純正の env 名は SAKANA_API_KEY だが、Hermes 側は OPENAI_API_KEY を見る）
OPENAI_API_KEY=sk-sakana-xxxxxxxxxxxxxxxxxxxxxxxx

# base_url は config/config.yaml の model.base_url で指定する（https://api.sakana.ai/v1）。
# env で上書きしたい場合のみ次を使う：
# OPENAI_BASE_URL=https://api.sakana.ai/v1

# --- ダッシュボード（127.0.0.1 のみ公開・Basic 認証必須） ------------------
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=change-me-to-a-long-random-string

# --- Discord（Bot Token 方式。Webhook URL ではない） -------------------------
# Webhook URL は一方通行（投稿専用）で会話できないので使わない。双方向の Bot Token が必須。
# 取得: https://discord.com/developers/applications でアプリ作成 → Bot ページ
#       → Message Content Intent を ON → Reset Token でトークン取得（1度しか表示されない）。
DISCORD_BOT_TOKEN=your-bot-token

# 自分の Discord User ID（設定→詳細設定→開発者モードON→自分を右クリック→ユーザーIDをコピー）。
# ⚠️ 未設定だと安全策で全ユーザーが拒否される。自分のIDだけ入れて自分専用にする。
DISCORD_ALLOWED_USERS=000000000000000000
